---
import TechStack from './TechStack.jsx';
import ProjectCard from './ProjectCard.astro';
import KnowledgeCard from './KnowledgeCard.astro';
import portfolioData from '../data/portfolio.json';

const projects = portfolioData.filter(item => item.type === 'project');
const knowledgeItem = portfolioData.find(item => item.type === 'knowledge');
---

<div class="grid grid-cols-1 gap-4 md:grid-cols-4 md:grid-rows-4 h-auto w-full max-w-6xl mx-auto p-4 md:p-0">
  
  {/* Hero / Intro (Top Full Width) */}
  <div class="col-span-1 md:col-span-4 md:row-span-1 rounded-3xl p-8 transition-all duration-500 glass-card glass-card-hover group relative overflow-hidden flex items-center min-h-[250px]">
    
    <div className="absolute top-0 right-0 w-96 h-96 bg-gradient-to-br from-purple-600/20 via-blue-600/10 to-transparent blur-3xl rounded-full translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>

    <div class="z-10 relative max-w-2xl">
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-slate-100 mb-2 font-inter">
        Hola, soy <span class="bg-gradient-to-r from-purple-400 via-pink-400 to-red-400 bg-clip-text text-transparent animate-gradient-x">Francisco</span>.
      </h1>
      <h2 class="text-xl md:text-2xl font-bold bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent mb-4">
        Ingeniero Informático & Game Dev
      </h2>
      <p class="text-base md:text-lg text-slate-400 leading-relaxed font-light">
        Transformando datos en <span class="text-slate-200 font-medium">estrategias de negocio</span> y código en <span class="text-slate-200 font-medium">experiencias inmersivas</span>.
      </p>
    </div>
  </div>

  {/* Knowledge Card (Theory) - Prominent */}
  <div class="col-span-1 md:col-span-1 md:row-span-2">
    <KnowledgeCard title={knowledgeItem.title} items={knowledgeItem.items} />
  </div>

  {/* Main Featured Project (Big Card) */}
  <div class="col-span-1 md:col-span-2 md:row-span-1">
     <ProjectCard {...projects[0]} />
  </div>

  {/* Tech Stack (Toolbox) - Interactive */}
  <div class="col-span-1 md:col-span-1 md:row-span-2">
    <TechStack client:visible /> 
  </div>

  {/* Secondary Projects Row */}
  <div class="col-span-1 md:col-span-1 md:row-span-1">
     <ProjectCard {...projects[1]} />
  </div>

   {/* Just a filler / Extra Project or Social - Let's fit Project 3 if exists */}
   <div class="col-span-1 md:col-span-1 md:row-span-1">
    {projects[2] ? <ProjectCard {...projects[2]} /> : (
      <div class="h-full flex flex-col justify-center items-center text-center rounded-3xl p-6 glass-card text-slate-500">
        <p>More Coming Soon...</p>
      </div>
    )}
  </div>

  {/* GitHub / Contact Tile */}
  <div class="col-span-1 md:col-span-1 md:row-span-1 rounded-3xl p-6 glass-card glass-card-hover flex flex-col justify-center items-center text-center cursor-pointer group hover:border-purple-500/30 hover:shadow-purple-500/20 transition-all bg-slate-900/60">
    <div class="w-12 h-12 bg-slate-800 rounded-full flex items-center justify-center mb-3 group-hover:scale-110 group-hover:bg-slate-700 transition-all shadow-inner border border-slate-700">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-200"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36.5-8 0C6 2 5 2 4 2c-1.2 2.1-1.2 3.5-1.2 3.5-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
    </div>
    <h3 class="font-bold text-slate-100">GitHub</h3>
    <p class="text-xs text-slate-500 font-mono mt-1">@yourusername</p>
  </div>
  
</div>
